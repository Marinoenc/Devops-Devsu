{
  "name": "demo-devops-nodejs",
  "version": "1.0.0",
  "description": "DevOps technical test - Node.js application dockerized and deployed to Kubernetes on Azure.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.js",
      "!coverage/**",
      "!node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "transform": {
      "^.+\\.js?$": "babel-jest"
    }
  },
  "author": "Devsu",
  "dependencies": {
    "express": "4.18.2",
    "sequelize": "6.31.0",
    "sqlite3": "5.1.6",
    "yup": "1.0.2"
  },
  "devDependencies": {
    "@babel/preset-env": "7.21.4",
    "@types/express": "4.17.17",
    "babel-jest": "29.5.0",
    "dotenv": "16.0.3",
    "eslint": "^8.57.0",
    "jest": "29.5.0",
    "supertest": "6.3.3"
  }
}
